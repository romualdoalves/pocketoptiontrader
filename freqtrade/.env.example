# =============================================================
# AlpacaTrader Freqtrade Stack — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================

# ── Alpaca Paper Trading ──────────────────────────────────────
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXX
ALPACA_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Freqtrade API Server ──────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FREQTRADE_JWT_SECRET=change_me_to_a_random_64_char_hex_string
FREQTRADE_API_PASSWORD=change_me_to_a_strong_password

# ── Google Cloud / BigQuery ───────────────────────────────────
# Project ID from GCP Console → home page
GCP_PROJECT_ID=your-gcp-project-id

# Path inside the container where the service-account JSON is mounted
# (leave as-is unless you change the docker-compose volume mount)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp_service_account.json

# BigQuery dataset (will be created by sync_to_bq.py if absent)
BQ_DATASET=alpacatrader

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# ── Optional: Telegram Alerts ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional: News Blackout (CryptoPanic) ────────────────────
CRYPTOPANIC_API_KEY=

# ── Deployment Region (informational) ────────────────────────
# GCP region used for this stack: europe-west8 (Milan)
GCP_REGION=europe-west8
