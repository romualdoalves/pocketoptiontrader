{
  "$schema": "https://raw.githubusercontent.com/freqtrade/freqtrade/stable/freqtrade/templates/config_schema.json",

  "trading_mode": "spot",
  "margin_mode": "",

  "max_open_trades": 1,
  "stake_currency": "USD",
  "stake_amount": 1000,
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",

  "dry_run": true,
  "dry_run_wallet": 100000,

  "cancel_open_orders_on_exit": true,

  "timeframe": "5m",

  "exchange": {
    "name": "alpaca",
    "key": "${ALPACA_API_KEY}",
    "secret": "${ALPACA_API_SECRET}",
    "ccxt_config": {
      "urls": {
        "api": {
          "public":  "https://paper-api.alpaca.markets",
          "private": "https://paper-api.alpaca.markets"
        }
      },
      "options": {
        "defaultType": "spot"
      }
    },
    "ccxt_async_config": {},
    "pair_whitelist": [
      "BTC/USD"
    ],
    "pair_blacklist": []
  },

  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],

  "entry_pricing": {
    "price_side": "same",
    "ask_last_balance": 0.0,
    "use_order_book": false,
    "order_book_top": 1,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },

  "exit_pricing": {
    "price_side": "same",
    "use_order_book": false,
    "order_book_top": 1
  },

  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "stoploss": "market",
    "stoploss_on_exchange": false
  },

  "order_time_in_force": {
    "entry": "GTC",
    "exit": "GTC"
  },

  "stoploss": -0.05,
  "trailing_stop": false,

  "strategy": "Strategy2LiquiditySentinel",
  "strategy_path": "/freqtrade/user_data/strategies",

  "db_url": "sqlite:////freqtrade/user_data/tradesv3.sqlite",

  "initial_state": "running",
  "internals": {
    "process_throttle_secs": 5
  },

  "telegram": {
    "enabled": false,
    "token": "${TELEGRAM_BOT_TOKEN}",
    "chat_id": "${TELEGRAM_CHAT_ID}",
    "notification_settings": {
      "status": "silent",
      "warning": "on",
      "startup": "on",
      "entry": "on",
      "exit": "on",
      "entry_cancel": "silent",
      "exit_cancel": "silent",
      "exit_fill": "on",
      "protection_trigger": "on",
      "protection_trigger_global": "on"
    }
  },

  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8888,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "${FREQTRADE_JWT_SECRET}",
    "CORS_origins": [],
    "username": "freqtrade",
    "password": "${FREQTRADE_API_PASSWORD}"
  },

  "bot_name": "AlpacaTrader-LiquiditySentinel",
  "force_entry_enable": false,
  "user_data_dir": "/freqtrade/user_data",

  "dataformat_ohlcv": "json",
  "dataformat_trades": "jsongz"
}
