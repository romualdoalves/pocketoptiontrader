# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env no controle de versão.

# ── PocketOption ──────────────────────────────────────────────────────────────
# Extraídas do navegador após login com Google Account em pocketoption.com

# Cookie ci_session — ainda usado no header HTTP do upgrade WebSocket (opcional)
POCKET_SSID=YOUR_CI_SESSION_COOKIE_HERE

# ID do usuário numérico (ex: 2197423 — visível na URL ou resposta de auth)
POCKET_UID=YOUR_USER_ID_HERE

# sessionToken — chave de autenticação do WebSocket (ex: b0f01b9e01a9a381be6a51a0ec8ddb83)
# Encontrado em DevTools → Network → WS → payload do evento "auth" enviado pelo browser
POCKET_SECRET=YOUR_SECRET_KEY_HERE

# Modo de conta: 1 = demo (recomendado para testes), 0 = conta real
POCKET_DEMO=1

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# Necessário apenas para meta_optimizer.py (Abordagem D, Nível 4)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# ── Database (TraderDev backend) ──────────────────────────────────────────────
DATABASE_URL=postgresql://crypto:crypto@localhost:5432/pocketoption

# ── Deploy (VPS Hostinger) ────────────────────────────────────────────────────
# Subdomínio: pocketoption.tradixio.com
# Docker + Traefik pré-instalados no VPS KVM4
# TLS automático via Let's Encrypt (Traefik certresolver=letsencrypt)
TRAEFIK_DOMAIN=pocketoption.tradixio.com
